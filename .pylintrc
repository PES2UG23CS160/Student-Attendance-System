[MESSAGES CONTROL]
disable =
    line-too-long,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    broad-exception-caught,
    bare-except,
    wrong-import-order,
    invalid-envvar-default,
    unused-import,
    unused-variable,
    import-error

[FORMAT]
max-line-length = 150
